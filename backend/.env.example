# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://presenter_user:presenter_pass@localhost:5432/presenter_ai"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# File Storage (local or S3)
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# AI Service Keys (mock in dev — replace with real keys)
OPENAI_API_KEY=
STABILITY_AI_KEY=
HEYGEN_API_KEY=
ELEVENLABS_API_KEY=

# Credits
DEFAULT_CREDITS=100
