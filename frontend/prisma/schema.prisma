generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum MediaType {
  VIDEO
  IMAGE
  AUDIO
  UGC
  TEXT
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String?
  name          String
  role          Role       @default(USER)
  credits       Int        @default(100)
  avatarUrl     String?
  githubId      String?    @unique
  githubLogin   String?
  googleId      String?    @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  campaigns     Campaign[]
  creditLogs    CreditLog[]

  @@map("users")
}

model Campaign {
  id              String   @id @default(uuid())
  userId          String
  title           String
  description     String?
  productImageUrl String?
  targetAudience  String?
  script          String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations     Generation[]

  @@map("campaigns")
}

model Generation {
  id           String           @id @default(uuid())
  campaignId   String
  mediaType    MediaType
  status       GenerationStatus @default(PENDING)
  prompt       String?
  resultUrl    String?
  thumbnailUrl String?
  metadata     Json?
  creditsUsed  Int              @default(0)
  errorMessage String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("generations")
}

model MagicLinkToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("magic_link_tokens")
}

model CreditLog {
  id          String   @id @default(uuid())
  userId      String
  delta       Int
  reason      String
  balanceAfter Int
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_logs")
}

model CoffeeMenuItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  emoji       String   @default("☕")
  category    String   @default("משקאות")
  available   Boolean  @default(true)
  sortOrder   Int      @default(0)
  ingredients Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("coffee_menu_items")
}

model CoffeeOrder {
  id           Int      @id @default(autoincrement())
  orderNumber  String   @unique @default(cuid())
  customerName String
  tableNote    String?
  items        Json
  total        Float
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("coffee_orders")
}
