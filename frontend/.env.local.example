# PostgreSQL — use Neon (neon.tech) for Vercel deployment (free tier)
DATABASE_URL="postgresql://user:password@host/presenter_ai?sslmode=require"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# In production: https://your-app.vercel.app/api/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# App URL (used by OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Credits
DEFAULT_CREDITS=100
